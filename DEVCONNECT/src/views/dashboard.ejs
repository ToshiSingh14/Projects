<!-- Update dashboard.ejs -->

<link rel="stylesheet" href="/css/style.css">

<nav>
    <a href="/dashboard">Dashboard</a>
    <a href="/create">Create Post</a>
    <a href="/logout">Logout</a>
</nav>

<div class="container">

<h1>Dashboard</h1>

<% if(posts.length === 0) { %>
    <h3>No posts available</h3>
<% } %>

<% posts.forEach(post => { %>

<div class="card">

    <h2><%= post.title %></h2>

    <p><%= post.content %></p>

    <p class="small">By <%= post.author.username %></p>

    <br>

    <a class="btn" href="/post/<%= post._id %>">View</a>

    <% if(post.author._id.toString() === userId) { %>

        <a class="btn" href="/post/edit/<%= post._id %>">Edit</a>

        <form action="/post/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
            <button type="submit">Delete</button>
        </form>

    <% } %>

</div>

<% }) %>

</div>